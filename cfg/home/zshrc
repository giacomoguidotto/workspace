alias la="tree"
lz() {
  local cfg_dir="${XDG_CONFIG_HOME:-$HOME/.config}/lazygit"
  local flavor
  if defaults read -g AppleInterfaceStyle &>/dev/null; then
    flavor=mocha
  else
    flavor=latte
  fi
  LG_CONFIG_FILE="$cfg_dir/config.yml,$cfg_dir/themes/$flavor-blue.yml" \
    lazygit "$@"
}
alias lzd="lazydocker"
alias lzq="lazysql"
alias rd="rm -rf"
alias spt="spotify_player"
alias tp="btop"
alias v="nvim"
alias x="exit"
alias za="zellij a"
alias zz="zellij"

# navigation
_fselect() { fd "$@" 2>/dev/null | fzf --height 40% --reverse --preview 'tree -C {} | head -100' --query "${@: -1}"; }

cx() { cd "$@" && l; }
mkcd() { mkdir -p "$1" && cd "$1" }
ff() { aerospace list-windows --all | fzf --bind 'enter:execute(bash -c "aerospace focus --window-id {1}")+abort'}

function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	command yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
	rm -f -- "$tmp"
}

klp() { for p in "$@"; do lsof -ti ":$p" | xargs kill -9 2>/dev/null && echo "killed port $p" || echo "no process on port $p"; done; }

# key bindings
bindkey jj vi-cmd-mode

# tools

# atuin - shell history
if command -v atuin > /dev/null 2>&1; then
  eval "$(atuin init zsh)"
fi

# carapace - completions
if command -v carapace > /dev/null 2>&1; then
  zstyle ':completion:*' format $'\e[2;37mCompleting %d\e[m'
  source <(carapace _carapace)
fi

# direnv - directory-specific environments
if command -v direnv > /dev/null 2>&1; then
  eval "$(direnv hook zsh)"
fi

# fzf - fuzzy finder
if command -v fzf > /dev/null 2>&1; then
  source <(fzf --zsh)
fi

# starship - prompt
if command -v starship > /dev/null 2>&1; then
  eval "$(starship init zsh)"
fi

# zoxide - directory jumping
if command -v zoxide > /dev/null 2>&1; then
  eval "$(zoxide init zsh)"
fi

# mise - declarative environment
eval "$(mise activate zsh)"
eval "$(mise completion zsh)"

# pitchfork - declarative deamons
eval "$(pitchfork activate zsh)"

# brew - the easiest way to clutter your workspace
eval "$(/opt/homebrew/bin/brew shellenv zsh)"

# bun completions
[ -s "/Users/giacomo/.bun/_bun" ] && source "/Users/giacomo/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# Launch pi with secrets injected from 1Password (NOTION_TOKEN, etc.).
# Edit ~/.config/pi/secrets.env to add more `op://...` references.
pi() {
  op run --env-file="$HOME/.config/pi/secrets.env" -- command pi "$@"
}
