// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
    "github-copilot-cli": {
      "favorite_config_option_values": {
        "model": ["claude-opus-4.8", "gpt-5.5"],
      },
      "default_config_options": {
        "reasoning_effort": "xhigh",
        "allow_all": "on",
        "model": "claude-opus-4.8",
      },
      "type": "registry",
    },
  },
  "cli_default_open_behavior": "new_window",
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "notification_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "right",
  },
  "project_panel": {
    "starts_open": false,
    "dock": "right",
  },
  "edit_predictions": {
    "enabled_in_text_threads": false,
    "mode": "subtle",
  },
  "agent": {
    "dock": "left",
    "default_model": {
      "effort": "medium",
      "enable_thinking": true,
      "provider": "openai-subscribed",
      "model": "gpt-5.5",
    },
  },

  "auto_update": false,
  "base_keymap": "Cursor",
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte (Blur) [Heavy]",
    "dark": "Catppuccin Mocha (Blur) [Heavy]",
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Mocha",
    "dark": "Catppuccin Mocha",
  },
  // "ui_font_family": "BlexMono Nerd Font Mono",
  "buffer_font_family": "BlexMono Nerd Font Mono",

  "terminal": {
    "font_family": "BlexMono Nerd Font Mono",
    "line_height": "standard",
  },

  "tab_size": 2,
  "ui_font_size": 14,
  "buffer_font_size": 14,

  "autosave": "on_focus_change",
  "format_on_save": "on",

  "code_actions_on_format": {
    "source.fixAll": true,
    "source.organizeImports": true,
  },

  "vim_mode": true,

  "wrap_guides": [80],
  "show_wrap_guides": true,
  "languages": {
    "Markdown": {
      "soft_wrap": "preferred_line_length",
    },
    "Python": {
      "language_servers": ["ty", "!basedpyright"],
    },
    "JavaScript": {
      "language_servers": ["!eslint", "..."],
    },
    "TypeScript": {
      "language_servers": ["!eslint", "..."],
    },
    "Proto": {
      "language_servers": ["!protobuf-language-server", "protols"],
    },
  },
  "lsp": {
    "nil": {
      "initialization_options": {
        "formatting": {
          "command": ["nixfmt"],
        },
      },
    },
  },

  "telemetry": { "metrics": false },
}
