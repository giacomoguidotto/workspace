layout {
    cwd "/Users/giacomo"
    tab name="orray" hide_floating_panes=true {
        pane split_direction="vertical" {
            pane command="lazygit" cwd="dev/life/orray" size="30%" {
                start_suspended true
            }
            pane command="claude" cwd="dev/life/orray" size="25%" {
                start_suspended true
            }
            pane command="claude" cwd="dev/life/orray" size="25%" {
                start_suspended true
            }
            pane size="20%" {
                pane command="tilt" cwd="dev/life/orray" size="17%" {
                    args "up"
                    start_suspended true
                }
                pane cwd="dev/life/orray" size="82%"
            }
        }
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
    }
    tab name="scry" hide_floating_panes=true {
        pane split_direction="vertical" {
            pane command="lazygit" cwd="dev/life/scry" size="35%" {
                start_suspended true
            }
            pane command="claude" cwd="dev/life/scry" size="32%" {
                start_suspended true
            }
            pane command="claude" cwd="dev/life/scry" size="32%" {
                start_suspended true
            }
        }
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
    }
    tab name="workspace" focus=true hide_floating_panes=true {
        pane split_direction="vertical" {
            pane command="lazygit" cwd="dev/life/workspace" size="35%" {
                start_suspended true
            }
            pane command="claude" cwd="dev/life/workspace" focus=true size="30%" {
                start_suspended true
            }
            pane command="claude" cwd="dev/life/workspace" size="35%" {
                start_suspended true
            }
        }
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
    }
    tab name="cs3" hide_floating_panes=true {
        pane split_direction="vertical" {
            pane command="lazygit" cwd="dev/work/coolselector3-mvp" size="35%" {
                start_suspended true
            }
            pane command="claude" cwd="dev/work/coolselector3-mvp/frontend" size="65%" {
                start_suspended true
            }
        }
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
    }
    tab name="pg" hide_floating_panes=true {
        pane split_direction="vertical" {
            pane command="btop" size="50%" {
                start_suspended true
            }
            pane size="50%"
        }
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
    }
    new_tab_template {
        pane cwd="/Users/giacomo"
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
    }
    swap_tiled_layout name="vertical" {
        tab max_panes=4 {
            pane {
                pane split_direction="vertical" {
                    pane
                    pane {
                        children
                    }
                }
            }
            pane size=1 borderless=true {
                plugin location="compact-bar"
            }
        }
        tab max_panes=7 {
            pane {
                pane split_direction="vertical" {
                    pane {
                        children
                    }
                    pane {
                        pane
                        pane
                        pane
                        pane
                    }
                }
            }
            pane size=1 borderless=true {
                plugin location="compact-bar"
            }
        }
        tab max_panes=11 {
            pane {
                pane split_direction="vertical" {
                    pane {
                        children
                    }
                    pane {
                        pane
                        pane
                        pane
                        pane
                    }
                    pane {
                        pane
                        pane
                        pane
                        pane
                    }
                }
            }
            pane size=1 borderless=true {
                plugin location="compact-bar"
            }
        }
    }
    swap_tiled_layout name="horizontal" {
        tab max_panes=3 {
            pane {
                pane
                pane
            }
            pane size=1 borderless=true {
                plugin location="compact-bar"
            }
        }
        tab max_panes=7 {
            pane {
                pane {
                    pane split_direction="vertical" {
                        children
                    }
                    pane split_direction="vertical" {
                        pane
                        pane
                        pane
                        pane
                    }
                }
            }
            pane size=1 borderless=true {
                plugin location="compact-bar"
            }
        }
        tab max_panes=11 {
            pane {
                pane {
                    pane split_direction="vertical" {
                        children
                    }
                    pane split_direction="vertical" {
                        pane
                        pane
                        pane
                        pane
                    }
                    pane split_direction="vertical" {
                        pane
                        pane
                        pane
                        pane
                    }
                }
            }
            pane size=1 borderless=true {
                plugin location="compact-bar"
            }
        }
    }
    swap_tiled_layout name="stacked" {
        tab min_panes=4 {
            pane {
                pane split_direction="vertical" {
                    pane
                    pane stacked=true {
                        children
                    }
                }
            }
            pane size=1 borderless=true {
                plugin location="compact-bar"
            }
        }
    }
    swap_floating_layout name="staggered" {
        floating_panes {
        }
    }
    swap_floating_layout name="enlarged" {
        floating_panes max_panes=10 {
            pane cwd="/Users/giacomo" {
                height "90%"
                width "90%"
                x "5%"
                y 1
            }
            pane cwd="/Users/giacomo" {
                height "90%"
                width "90%"
                x "5%"
                y 2
            }
            pane cwd="/Users/giacomo" {
                height "90%"
                width "90%"
                x "5%"
                y 3
            }
            pane cwd="/Users/giacomo" {
                height "90%"
                width "90%"
                x "5%"
                y 4
            }
            pane cwd="/Users/giacomo" {
                height "90%"
                width "90%"
                x "5%"
                y 5
            }
            pane cwd="/Users/giacomo" {
                height "90%"
                width "90%"
                x "5%"
                y 6
            }
            pane cwd="/Users/giacomo" {
                height "90%"
                width "90%"
                x "5%"
                y 7
            }
            pane cwd="/Users/giacomo" {
                height "90%"
                width "90%"
                x "5%"
                y 8
            }
            pane cwd="/Users/giacomo" {
                height "90%"
                width "90%"
                x "5%"
                y 9
            }
            pane cwd="/Users/giacomo" {
                height "90%"
                width "90%"
                x 10
                y 10
            }
        }
    }
    swap_floating_layout name="spread" {
        floating_panes max_panes=1 {
            pane cwd="/Users/giacomo" {
                x "50%"
                y "50%"
            }
        }
        floating_panes max_panes=2 {
            pane cwd="/Users/giacomo" {
                width "45%"
                x "1%"
                y "25%"
            }
            pane cwd="/Users/giacomo" {
                width "45%"
                x "50%"
                y "25%"
            }
        }
        floating_panes max_panes=3 {
            pane cwd="/Users/giacomo" {
                height "45%"
                width "45%"
                y "55%"
            }
            pane cwd="/Users/giacomo" {
                width "45%"
                x "1%"
                y "1%"
            }
            pane cwd="/Users/giacomo" {
                width "45%"
                x "50%"
                y "1%"
            }
        }
        floating_panes max_panes=4 {
            pane cwd="/Users/giacomo" {
                height "45%"
                width "45%"
                x "1%"
                y "55%"
            }
            pane cwd="/Users/giacomo" {
                height "45%"
                width "45%"
                x "50%"
                y "55%"
            }
            pane cwd="/Users/giacomo" {
                height "45%"
                width "45%"
                x "1%"
                y "1%"
            }
            pane cwd="/Users/giacomo" {
                height "45%"
                width "45%"
                x "50%"
                y "1%"
            }
        }
    }
}
